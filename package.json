{
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "backend"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run backend/src/__tests__/e2e.test.ts",
    "test:data-integrity": "vitest run backend/src/__tests__/data-integrity.test.ts",
    "guard:serverless": "powershell -ExecutionPolicy Bypass -File scripts/assert-serverless-only.ps1",
    "guard:no-sms": "powershell -ExecutionPolicy Bypass -File scripts/assert-phone-otp-disabled.ps1",
    "guard:no-dashes": "powershell -ExecutionPolicy Bypass -File scripts/assert-no-em-dashes.ps1",
    "fix:no-dashes": "powershell -ExecutionPolicy Bypass -File scripts/assert-no-em-dashes.ps1 -Fix",
    "sync:rules": "node scripts/sync-ai-rules.mjs",
    "guard:rules": "node scripts/sync-ai-rules.mjs --check",
    "guard:all": "pnpm guard:serverless && pnpm guard:no-sms && pnpm guard:no-dashes && pnpm guard:rules",
    "prepare": "husky"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "fast-check": "^4.6.0",
    "husky": "^9.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.2"
  }
}
