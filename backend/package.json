{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx tsx --watch src/server.ts",
    "build": "npx tsx build.mts",
    "build:lambda": "npx tsx build.mts",
    "test": "vitest run",
    "test:data-integrity": "vitest run src/__tests__/data-integrity.test.ts",
    "backfill:user-locks": "npx tsx src/scripts/backfill-user-locks.ts",
    "backfill:user-search": "npx tsx src/scripts/backfill-user-search.ts",
    "backfill:redemption-code-aliases": "npx tsx src/scripts/backfill-redemption-code-aliases.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@area-code/shared": "workspace:*",
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1020.0",
    "@aws-sdk/client-cloudwatch": "^3.1020.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1020.0",
    "@aws-sdk/client-dynamodb": "^3.1038.0",
    "@aws-sdk/client-lambda": "^3.1057.0",
    "@aws-sdk/client-pinpoint-sms-voice-v2": "^3.1039.0",
    "@aws-sdk/client-s3": "^3.1020.0",
    "@aws-sdk/client-sesv2": "^3.1045.0",
    "@aws-sdk/client-sqs": "^3.1020.0",
    "@aws-sdk/lib-dynamodb": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1020.0",
    "@aws-sdk/util-dynamodb": "^3.996.0",
    "@fastify/aws-lambda": "^5.0.0",
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.8.4",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "sharp": "^0.33.5",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/web-push": "^3.6.4",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
