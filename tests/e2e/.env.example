# ── Target environment ──────────────────────────────────────────────────────
# One of: local, staging, prod (avoid prod unless you really mean it)
E2E_ENV=staging

# ── URLs (override per environment) ─────────────────────────────────────────
E2E_API_URL=https://api.staging.areacode.co.za
E2E_CONSUMER_URL=https://staging.areacode.co.za
E2E_BUSINESS_URL=https://business.staging.areacode.co.za
E2E_STAFF_URL=https://staff.staging.areacode.co.za
E2E_ADMIN_URL=https://admin.staging.areacode.co.za

# ── AWS / Cognito (used by global-setup to seed test users) ─────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

AREA_CODE_COGNITO_CONSUMER_USER_POOL_ID=us-east-1_XXXXXXXXX
AREA_CODE_COGNITO_CONSUMER_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
AREA_CODE_COGNITO_BUSINESS_USER_POOL_ID=us-east-1_XXXXXXXXX
AREA_CODE_COGNITO_BUSINESS_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
AREA_CODE_COGNITO_STAFF_USER_POOL_ID=us-east-1_XXXXXXXXX
AREA_CODE_COGNITO_STAFF_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
AREA_CODE_COGNITO_ADMIN_USER_POOL_ID=us-east-1_XXXXXXXXX
AREA_CODE_COGNITO_ADMIN_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Test account passwords (use long random strings; rotate after leaks) ────
E2E_TEST_PASSWORD=ChangeMe!ToALongRandomString-9f3kP2Lq

# ── Optional: keep seeded users between runs to speed up local iteration ────
# When set to "1", global-teardown skips disabling users.
E2E_KEEP_USERS=0
