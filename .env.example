# ── App ──────────────────────────────────────────────────────────────────────
AREA_CODE_ENV=dev
AREA_CODE_CONSENT_VERSION=v1.0

# ── Error Monitoring (Sentry) ────────────────────────────────────────────────
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
VITE_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# ── Database ─────────────────────────────────────────────────────────────────
AREA_CODE_DB_URL=postgresql://user:pass@localhost:5432/area_code
AREA_CODE_DB_READ_URL=postgresql://user:pass@localhost:5432/area_code

# ── Redis ────────────────────────────────────────────────────────────────────
AREA_CODE_REDIS_URL=redis://localhost:6379

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=af-south-1
AREA_CODE_S3_MEDIA_BUCKET=area-code-dev-media

# ── SMS (End User Messaging v2 — South Africa) ──────────────────────────────
# Sender ID is configured via Terraform (AREACODE alphanumeric, no ZA registration required)
# Configuration Set and Protect Configuration are managed in infra/modules/sms
# Set AREA_CODE_FORCE_LIVE=1 to enable real SMS sending in dev mode

# ── Cognito — Consumer pool ───────────────────────────────────────────────────
AREA_CODE_COGNITO_CONSUMER_USER_POOL_ID=us-east-1_XXXXXXXXX
AREA_CODE_COGNITO_CONSUMER_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_USER_POOL_ID_CONSUMER=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID_CONSUMER=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Hosted UI hostname only (no https). Consumer Google OAuth + PKCE (apps/web).
VITE_COGNITO_HOSTED_UI_DOMAIN=area-code-prod-consumer.auth.us-east-1.amazoncognito.com

# Expo consumer Google OAuth (apps/mobile app.config extra)
EXPO_PUBLIC_COGNITO_HOSTED_UI_DOMAIN=area-code-prod-consumer.auth.us-east-1.amazoncognito.com
EXPO_PUBLIC_COGNITO_CLIENT_ID_CONSUMER=xxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_API_URL=http://localhost:4000

# ── Cognito — Business pool ───────────────────────────────────────────────────
AREA_CODE_COGNITO_BUSINESS_USER_POOL_ID=us-east-1_XXXXXXXXX
AREA_CODE_COGNITO_BUSINESS_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_USER_POOL_ID_BUSINESS=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID_BUSINESS=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Hosted UI hostname only (business dashboard Google OAuth + PKCE). Redirect: https://localhost:3001/auth/callback (dev), prod origin + /auth/callback
VITE_COGNITO_HOSTED_UI_DOMAIN_BUSINESS=area-code-prod-business.auth.af-south-1.amazoncognito.com

# ── Cognito — Staff pool ──────────────────────────────────────────────────────
AREA_CODE_COGNITO_STAFF_USER_POOL_ID=us-east-1_XXXXXXXXX
AREA_CODE_COGNITO_STAFF_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_CLIENT_ID_STAFF=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_HOSTED_UI_DOMAIN_STAFF=area-code-prod-staff.auth.af-south-1.amazoncognito.com

# ── Cognito — Admin pool ──────────────────────────────────────────────────────
AREA_CODE_COGNITO_ADMIN_USER_POOL_ID=us-east-1_XXXXXXXXX
AREA_CODE_COGNITO_ADMIN_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_CLIENT_ID_ADMIN=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_HOSTED_UI_DOMAIN_ADMIN=area-code-prod-admin.auth.af-south-1.amazoncognito.com

# ── Mapbox ────────────────────────────────────────────────────────────────────
VITE_MAPBOX_TOKEN=pk.eyJ1IjoiYXJlYWNvZGUiLCJhIjoiX...
AREA_CODE_MAPBOX_TOKEN_MOBILE=pk.eyJ1IjoiYXJlYWNvZGUiLCJhIjoiX...
MAPBOX_DOWNLOADS_TOKEN=sk.eyJ1IjoiYXJlYWNvZGUiLCJhIjoiX...

# ── Yoco payments ────────────────────────────────────────────────────────────
YOCO_DEV_SECRET_KEY=sk_test_XXXXXXXXXXXX
YOCO_DEV_PUBLIC_KEY=pk_test_XXXXXXXXXXXX
YOCO_PROD_SECRET_KEY=sk_live_XXXXXXXXXXXX
YOCO_PROD_PUBLIC_KEY=pk_live_XXXXXXXXXXXX
YOCO_WEBHOOK_SECRET=<webhook signing secret from Yoco dashboard>

# ── QR check-in ───────────────────────────────────────────────────────────────
AREA_CODE_QR_HMAC_SECRET=<generate: openssl rand -hex 32>

# ── Push notifications ────────────────────────────────────────────────────────
AREA_CODE_VAPID_PUBLIC_KEY=<generate: npx web-push generate-vapid-keys>
AREA_CODE_VAPID_PRIVATE_KEY=<generate: npx web-push generate-vapid-keys>
AREA_CODE_VAPID_SUBJECT=mailto:tech@areacode.co.za
VITE_VAPID_PUBLIC_KEY=<same as AREA_CODE_VAPID_PUBLIC_KEY>

# ── SQS ──────────────────────────────────────────────────────────────────────
AREA_CODE_REWARD_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/XXXX/area-code-dev-reward-eval
AREA_CODE_SQS_PUSH_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/XXXX/area-code-dev-push-sender

# ── Third-party ───────────────────────────────────────────────────────────────
AREA_CODE_FINGERPRINT_PRO_KEY=<FingerprintJS Pro secret key>
AREA_CODE_CIPC_API_KEY=<CIPC API key>

# ── Spotify OAuth (https://developer.spotify.com/dashboard) ──────────────────
# IMPORTANT: SPOTIFY_REDIRECT_URI must EXACTLY match a URI registered in your
# Spotify app dashboard. In prod we proxy /api/* through Amplify to the API Gateway,
# so the clean URL works. Local dev uses localhost.
SPOTIFY_CLIENT_ID=<your Spotify app client ID>
SPOTIFY_CLIENT_SECRET=<your Spotify app client secret>
SPOTIFY_REDIRECT_URI=http://localhost:4000/v1/streaming/spotify/callback
# In prod (set via Terraform var spotify_redirect_uri):
#   https://areacode.co.za/api/v1/streaming/spotify/callback

# ── Apple Music (https://developer.apple.com → MusicKit) ─────────────────────
APPLE_MUSIC_TEAM_ID=<your Apple Developer Team ID>
APPLE_MUSIC_KEY_ID=<your MusicKit Key ID>
APPLE_MUSIC_PRIVATE_KEY=<PEM-encoded .p8 key content, newlines as \n>

# ── Socket server ─────────────────────────────────────────────────────────────
PORT=4000
VITE_API_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000
VITE_WEBSOCKET_URL=wss://<websocket-api-id>.execute-api.us-east-1.amazonaws.com/prod
